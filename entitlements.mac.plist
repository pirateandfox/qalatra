<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Required for Electron's V8 JIT -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <!-- Required for Electron's V8 heap -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <!-- Required for native modules (better-sqlite3, node-pty) -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <!-- Network servers on localhost (api.js port 3456, mcp port 3457) -->
  <key>com.apple.security.network.server</key>
  <true/>
  <key>com.apple.security.network.client</key>
  <true/>
  <!-- Read/write access for attachments, database in userData -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>
</dict>
</plist>
